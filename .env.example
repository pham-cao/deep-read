# Google OAuth2 Credentials
# Get these from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# JWT Secret (use a strong random string in production)
SECRET_KEY=your-secret-key-here

# Frontend URL for redirects
FRONTEND_URL=http://localhost:5173

# Backend URL (used for OAuth redirect_uri)
BACKEND_URL=http://localhost:8000

# PostgreSQL Database Configuration
# Must match the values in DATABASE_URL below
POSTGRES_USER=deepread
POSTGRES_PASSWORD=deepread_pass
POSTGRES_DB=deepread

# Database connection URL - used by backend
# For Docker Compose: use 'postgres' as hostname
# For local dev: use 'localhost' as hostname
DATABASE_URL=postgresql+asyncpg://deepread:deepread_pass@postgres:5432/deepread
